# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'StyleFlattenBenchmark' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    malformed_flags = '-DRCT_NEW_ARCH_ENABLED=1-DUSE_HERMES=1'
    fixed_flags = '-DRCT_NEW_ARCH_ENABLED=1 -DUSE_HERMES=1'
    fix_flags = lambda { |value|
      value.is_a?(String) ? value.gsub(malformed_flags, fixed_flags) : value
    }

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        header_search_paths = build_config.build_settings['HEADER_SEARCH_PATHS'] || ['$(inherited)']
        header_search_paths = header_search_paths.split(' ') if header_search_paths.is_a?(String)
        header_search_paths << '"$(PODS_ROOT)/Headers/Private/Yoga"'
        build_config.build_settings['HEADER_SEARCH_PATHS'] = header_search_paths.uniq

        cplusplus_flags = build_config.build_settings['OTHER_CPLUSPLUSFLAGS']
        build_config.build_settings['OTHER_CPLUSPLUSFLAGS'] = fix_flags.call(cplusplus_flags)
      end

      next unless target.respond_to?(:source_build_phase)

      target.source_build_phase.files.each do |build_file|
        settings = build_file.settings
        next unless settings.is_a?(Hash)

        compiler_flags = settings['COMPILER_FLAGS']
        next unless compiler_flags.is_a?(String)

        settings['COMPILER_FLAGS'] = fix_flags.call(compiler_flags)
      end
    end

    generated_flag_files = [
      File.join(installer.sandbox.root.to_s, 'Target Support Files', '**', '*.xcconfig'),
      File.join(installer.sandbox.root.to_s, 'Local Podspecs', '*.podspec.json'),
    ]

    generated_flag_files.flat_map { |pattern| Dir.glob(pattern) }.each do |path|
      contents = File.read(path)
      fixed_contents = fix_flags.call(contents)
      File.write(path, fixed_contents) if fixed_contents != contents
    end
  end
end
